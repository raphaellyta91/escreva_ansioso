<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Histórico de Fatos</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<main class="container">

  <h1>Histórico: Fato ou Interpretação</h1>

  <% if (fatos.length === 0) { %>

    <p>Nenhum registro encontrado.</p>

  <% } else { %>

    <% fatos.forEach(fato => { %>

      <div class="card">

        <p><strong>Fato real:</strong></p>
        <p><%= fato.fatoReal %></p>

        <p><strong>Interpretação da ansiedade:</strong></p>
        <p><%= fato.interpretacao %></p>

        <p>
          <strong>Data:</strong>
          <%= fato.createdAt.toLocaleString('pt-BR') %>
        </p>

        <div class="acoes">

          <a
            class="botao-secundario"
            href="/fatos/<%= fato.id %>/editar">

            Editar

          </a>

          <form
            action="/fatos/<%= fato.id %>/excluir"
            method="POST">

            <button
              class="botao-excluir"
              type="submit">

              Excluir

            </button>

          </form>

        </div>

      </div>

    <% }) %>

  <% } %>

  <a href="/fato" class="botao">
    Novo Registro
  </a>

  <a href="/home" class="voltar">
    ← Menu Principal
  </a>

</main>

<%- include('../partials/footer') %>

</body>
</html>