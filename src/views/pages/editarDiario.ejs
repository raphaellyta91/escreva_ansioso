<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Editar Diário</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<main class="container">

  <h1>Editar Diário Emocional</h1>

  <form action="/diario/<%= diario.id %>/atualizar" method="POST">

    <label>O que aconteceu?</label>

    <textarea
      name="situacao"
      required><%= diario.situacao %></textarea>

    <label>Como você está se sentindo?</label>

    <input
      type="text"
      name="emocao"
      value="<%= diario.emocao %>"
      required
    >

    <label>Intensidade da emoção</label>

    <select name="intensidade" required>

      <% for (let i = 1; i <= 10; i++) { %>

        <option
          value="<%= i %>"
          <%= diario.intensidade == i ? 'selected' : '' %>>
          <%= i %>
        </option>

      <% } %>

    </select>

    <button type="submit">
      Salvar Alterações
    </button>

  </form>

  <a href="/historico" class="botao">
    Voltar para Histórico
  </a>

  <a href="/home" class="voltar">
    ← Menu Principal
  </a>

</main>

<%- include('../partials/footer') %>

</body>
</html>