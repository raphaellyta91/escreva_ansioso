<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Mensagens Salvas</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<main class="container">

  <h1>📨 Mensagens Salvas</h1>

  <p>
    Aqui ficam armazenadas as mensagens escritas no modo
    <strong>Não Envie Agora</strong>.
  </p>

  <% if (mensagens.length === 0) { %>

    <p>Nenhuma mensagem salva.</p>

  <% } else { %>

    <% mensagens.forEach(mensagem => { %>

      <div class="card">

        <p><strong>Mensagem:</strong></p>

        <p><%= mensagem.texto %></p>

        <p>
          <strong>Data:</strong>
          <%= mensagem.createdAt.toLocaleString('pt-BR') %>
        </p>

        <div class="acoes">

          <a
            class="botao-secundario"
            href="/mensagens/<%= mensagem.id %>/editar">

            Editar

          </a>

          <form
            action="/mensagens/<%= mensagem.id %>/excluir"
            method="POST">

            <button
              class="botao-excluir"
              type="submit">

              Excluir

            </button>

          </form>

        </div>

      </div>

    <% }) %>

  <% } %>

  <a href="/nao-envie-agora" class="botao">
    Nova Mensagem
  </a>

  <a href="/home" class="voltar">
    ← Menu Principal
  </a>

</main>

<%- include('../partials/footer') %>

</body>
</html>